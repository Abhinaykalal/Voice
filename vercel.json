{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "env": {
    "NODE_VERSION": "18"
  },
  "experimentalServices": {
    "frontend": {
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "server.js",
      "routePrefix": "/api"
    }
  }
}
