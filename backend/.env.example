# Groq API Configuration (Required for high accuracy)
GROQ_API_KEY=your_groq_api_key_here

# Supabase Configuration (Optional - for database storage)
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
USE_SUPABASE=true

# Railway Deployment Configuration
NODE_ENV=production
PORT=3000

# CORS Configuration
FRONTEND_URL=https://voice-abhinaykalal.netlify.app

# API Configuration
MAX_FILE_SIZE=25MB
SUPPORTED_FORMATS=audio/webm,audio/wav,audio/mp3,audio/mpeg,audio/ogg
